{
   "client": {
      "address" : "",
      "port" : 8085,
      "tlsMode": true,
      "verifyPeer": true,
      "caVerificationFile": "myCA.pem",

      "privateKeyFile": "",
      "privateKeyPassword": "",
      "certificateFile": "",

      "timeoutRead": 60,
      "timeoutWrite": 60,
      "timeoutProcessing": 120,
      "readBufferSize": 65536,
      "sendBufferSize": 65536,
      "maxHeaderSize": 65536,
      "connectionPoolSize": 2,
      "maxRequestsPerConnection": 100,
      "logVerbose": true,
      "temporaryDir": ""
   },
   "logging": {
      "multiSinkLevel": "info",
      "stdoutColor": {
         "level": "info",
         "pattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v"
      },
      "fileSink": {
         "level": "debug",
         "pattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v",
         "filePath": "logs/tobasa_log_d.txt",
         "truncate": false,
         "enable": true
      },
      "fileSinkD": {
         "level": "trace",
         "pattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v",
         "filePath": "logs/tobasa_log_t.txt",
         "truncate": false,
         "enable": true
      }
   }
}
