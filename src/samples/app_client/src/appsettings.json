{
   "logging": {
      "multiSinkLevel": "info",
      "stdoutColor": {
         "level": "info",
         "pattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v"
      },
      "fileSink": {
         "level": "debug",
         "pattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v",
         "filePath": "logs/tobasa_log_d.txt",
         "truncate": false,
         "enable": true
      },
      "fileSinkD": {
         "level": "trace",
         "pattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v",
         "filePath": "logs/tobasa_log_t.txt",
         "truncate": false,
         "enable": true
      }
   }
}