{
   "configVariables": {
      "${WS_DATADIR}": "./appdata",
      "${WS_LOGDIR}": "./appdata/log",
      "${DBSUFFIX}": ""
   },
   "securitySalt": "C4BC3A3AC2D6D367A74580388B20BC069C96B048DFEAF5CCDC0CE1E25BF23F39BBBKOKLPMKOJ",
   "webapp": {
      "environment": "production",
      "dbConnection": {
         "production": {
            "dbDriver": "SQLITE",
            "connectionString": "Database=${WS_DATADIR}/tobasa_base${DBSUFFIX}.db3;OpenCreate=True;OpenMemory=False;",
            "password": ""
         },
         "development": {
            "dbDriver": "SQLITE",
            "connectionString": "Database=${WS_DATADIR}/tobasa_base${DBSUFFIX}.db3;OpenCreate=True;OpenMemory=False;",
            "password": ""
         },
         "environment": "production",
         "logInternalSqlQuery": false,
         "logSqlQuery": false
      },
      "dbConnectionPoolSize": 4,
      "httpServer": {
         "runHttpsOnly": false,
         "http2Enabled": false,
         "address": "0.0.0.0",
         "port": 8084,
         "portHttps": 8085,
         "timeoutRead": 60,
         "timeoutWrite": 60,
         "timeoutProcessing": 60,
         "readBufferSize": 131072,
         "sendBufferSize": 131072,
         "maxHeaderSize": 8192,
         "maxRequestsPerConnection": 100,
         "docRoot": "wwwroot",
         "tls": {
            "certificateChainFile": "./tls_asset/127.0.0.1.crt",
            "privateKeyFile": "./tls_asset/127.0.0.1.key",
            "password": "",
            "tmpDhFile": "./tls_asset/dh2048.pem",
            "hostCertificates": [
               {
                  "hostname": "localhost",
                  "certificateChainFile": "./tls_asset/localhost.crt",
                  "privateKeyFile": "./tls_asset/localhost.key",
                  "password": ""
               }
            ]
         },
         "ioPoolSize": 4,
         "workerPoolSize": 4,
         "logVerbose": false,
         "logVerboseHttp2": false,
         "useRateLimiter": false,
         "rateLimiterMaxRequests": 200,
         "rateLimiterWindowDuration": 1000,
         "rateLimiterBlockDuration": 30000,
         "rateLimiterMaxViolations": 5,
         "enableMultipartParsing": false,
         "temporaryDir": "${WS_DATADIR}/tmp",
         "compression" : {
            "enable": true,
            "minimalLength" : 8092,
            "encoding" : "gzip",
            "mimetypes" : "text/html text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml" 
         }
      },
      "webService": {
         "routeAuthLists": {
            "noAuthenticationList": [
               { "path": "/api/encrypt", "check": "starts_with", "authScheme": "bearer" },
               { "path": "/api/decrypt", "check": "starts_with", "authScheme": "bearer" }
            ],
            "needAuthenticationList": []
         },
         "noSessionList": [],
         "sessionExpirationMinutes": 60,
         "sessionSavePath": "${WS_DATADIR}/session",
         "acceptedClientAppId": "TBSRESTC_DEV,TBSRESTC_TOBASA",
         "authJwtIssuer": "TBS_WEBSVC",
         "authJwtSecret": "C4BC3A3AC2D6D367A74580388B20BC069C96B048DFEAF5CCDC0CE1E25BF23F39BBBKOKLPMKOJXXXLITWOERTYCBNVCXJBOAI49540KDHGASGIAHETGIDOGHOZ0E9RUIHGAHOIHDA",
         "authJwtSecretRefresh": "C4BC3A3AC2D6D367A74580388B20BC069C96B048DFEAF5CCDC0CE1E25BF23F3",
         "authJwtExpireTimeSpanMinutes": 10,
         "authJwtRefreshExpireTimeSpanMinutes": 1440,
         "useInMemoryResources": true,
         "templateDir": "views",
         "uploadDir": "${WS_DATADIR}/upload",
         "dataDir": "${WS_DATADIR}",
         "homePage": "/dashboard",
         "loginPage": "/login",
         "logoutPage": "/logout"
      }
   },
   "logging": {
      "multiSinkLevel": "trace",
      "stdoutColor": {
         "level": "debug",
         "pattern": "[%Y%m%d_%H%M%S.%e][%t][%^%l%$] %v"
      },
      "fileSink": {
         "level": "debug",
         "pattern": "[%Y%m%d_%H%M%S.%e][%t][%^%l%$] %v",
         "filePath": "${WS_LOGDIR}/tobasa_%Y%m%d_%H%M%S.log",
         "truncate": false,
         "enable": true
      },
      "fileSinkD": {
         "level": "trace",
         "pattern": "[%Y%m%d_%H%M%S.%e][%t][%^%l%$] %v",
         "filePath": "${WS_LOGDIR}/tobasa_%Y%m%d_%H%M%S_D.log",
         "truncate": false,
         "enable": false
      }
   }
}